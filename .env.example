# ─────────────────────────────────────────────────────────────
# GC Growth API — Environment Variables
# Copy this file to .env.local for local dev (vercel dev)
# Add all of these in: Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # service_role key (NOT the anon key)

# Anthropic (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated list of allowed origins, or * to allow all
# Example: https://gcgrowth.vercel.app,https://app.gcgrowth.io
ALLOWED_ORIGINS=*
